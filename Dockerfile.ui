# Dockerfile.ui — OpenAgent Python web UI
#
# Runs the FastAPI + HTMX admin dashboard.
# The Rust openagent runtime is expected on the host (or at OPENAGENT_API_URL).
#
# Build:
#   docker build -f Dockerfile.ui -t openagent-ui .
# Run standalone:
#   docker run -p 8000:8000 -e OPENAGENT_API_URL=http://host.docker.internal:8080 openagent-ui

FROM python:3.11-slim

WORKDIR /app

# Install uv for fast dependency resolution
RUN pip install --no-cache-dir uv

# Copy README (required by pyproject.toml readme field if present)
COPY README.md .

# Copy app source (includes openagent/ sub-package)
COPY app/ app/

# Install the app and all its declared dependencies from app/pyproject.toml.
# Not editable — no -e flag needed in production Docker images.
RUN uv pip install --system --no-cache app/

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
