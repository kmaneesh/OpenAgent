# OpenAgent configuration
# Copy this file to config/openagent.yaml and edit as needed.
# Secrets (api_key) can be placed in .env or set as environment variables —
# env vars always take priority over values in this file.
#
# Env-var overrides:
#   OPENAGENT_PROVIDER_KIND   — openai_compat | anthropic | openai
#   OPENAGENT_LLM_BASE_URL    — full base URL (e.g. http://localhost:1234/v1)
#   OPENAGENT_API_KEY         — API key / bearer token
#   OPENAGENT_MODEL           — model name to request
#   OPENAGENT_LLM_TIMEOUT     — request timeout in seconds (float)

provider:
  # ── Option A: local OpenAI-compatible server (LM Studio, Ollama, llama.cpp) ──
  kind: openai_compat
  base_url: http://100.74.210.70:1234/v1
  api_key: ""          # leave blank for unauthenticated local servers
  model: ""            # empty = use server default / first available model
  timeout: 60.0
  max_tokens: 2048

  # ── Option B: Anthropic Claude ───────────────────────────────────────────────
  # kind: anthropic
  # base_url: ""       # leave blank to use https://api.anthropic.com
  # api_key: sk-ant-...
  # model: claude-sonnet-4-6
  # timeout: 60.0
  # max_tokens: 2048

  # ── Option C: OpenAI / Codex ─────────────────────────────────────────────────
  # kind: openai
  # base_url: ""       # leave blank to use https://api.openai.com/v1
  # api_key: sk-...
  # model: gpt-4o
  # timeout: 60.0
  # max_tokens: 2048
